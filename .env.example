# ============================================
# MOUL TABLEAUX — Frontend Environment Variables
# ============================================
# For Vercel deployment, set these in the Vercel dashboard
# For local development, keep as-is

# Backend API URL
# Production: https://your-backend-url.onrender.com/api
# Local: http://localhost:3001/api
VITE_API_URL=http://localhost:3001/api

# Backend WebSocket URL (for real-time notifications)
# Production: https://your-backend-url.onrender.com
# Local: http://localhost:3001
VITE_WS_URL=http://localhost:3001

# Supabase (optional — only if using Supabase auth)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
